{
  "name": "chat-system-server",
  "version": "1.1.0",
  "description": "Real-Time Chat System Backend",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "node ../tests/chat.test.js",
